package pages

import (
	"github.com/flowline-io/flowbot/pkg/types/model"
	"github.com/flowline-io/flowbot/pkg/views/layout"
	"github.com/flowline-io/flowbot/pkg/views/partials"
)

templ AgentSessionDetailPage(session model.AgentSession, entries []model.AgentSessionEntry, plans []model.AgentPlan, todos []model.AgentTodo) {
	@layout.Base(partials.AgentSessionPageTitle(session)) {
		if session.Title != "" {
			@partials.PageHeader(session.Title, session.Flag) {
				<a href="/service/web/agent-sessions" class="btn btn-ghost btn-sm" data-testid="agent-session-back">← Back to Sessions</a>
			}
		} else {
			@partials.PageHeader(session.Flag, "") {
				<a href="/service/web/agent-sessions" class="btn btn-ghost btn-sm" data-testid="agent-session-back">← Back to Sessions</a>
			}
		}
		<div
			id="chatagent-status-toast"
			class="chatagent-status-toast hidden shrink-0 mb-3 alert py-2 text-sm"
			data-testid="chatagent-status-toast"></div>
		@partials.ChatAgentApprovalPanel(session.Flag, partials.ChatAgentEndpoints{
			ConfirmURL: "/service/web/agent-sessions/" + session.Flag + "/confirm",
			EventsURL:  "/service/web/agent-sessions/" + session.Flag + "/events",
		})
		<div class="flowbot-surface mb-6">
			<div class="card-body">
				<div class="grid grid-cols-2 gap-2 text-sm text-base-content/70">
					if session.Title != "" {
						<div>
							<span class="text-base-content/50">Session ID:</span>
							<code class="text-xs ml-1">{ session.Flag }</code>
						</div>
					}
					<div>
						<span class="text-base-content/50">UID:</span>
						<span class="font-mono text-xs ml-1">{ session.UID }</span>
					</div>
					<div>
						<span class="text-base-content/50">State:</span>
						@partials.AgentSessionStateBadge(session.State)
					</div>
					<div>
						<span class="text-base-content/50">Leaf ID:</span>
						if session.LeafID != "" {
							<code class="text-xs ml-1">{ session.LeafID }</code>
						} else {
							<span class="text-base-content/30 ml-1">-</span>
						}
					</div>
					<div>
						<span class="text-base-content/50">Created:</span>
						<span class="ml-1">{ session.CreatedAt.Format("2006-01-02 15:04:05") }</span>
					</div>
					<div>
						<span class="text-base-content/50">Updated:</span>
						<span class="ml-1">{ session.UpdatedAt.Format("2006-01-02 15:04:05") }</span>
					</div>
				</div>
			</div>
		</div>
		@partials.AgentSessionPlansCard(session.Flag, plans)
		@partials.AgentSessionTodosCard(todos)
		<h2 class="text-lg font-semibold mb-3">Entries</h2>
		@partials.AgentSessionEntriesTable(entries)
		@partials.ChatAgentApprovalScripts()
	}
}
