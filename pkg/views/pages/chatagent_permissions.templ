package pages

import "github.com/flowline-io/flowbot/pkg/views/layout"
import "github.com/flowline-io/flowbot/pkg/views/partials"

templ ChatAgentPermissionsPage(data partials.PermissionFormPageData) {
	@layout.Base("Chat Agent Permissions — Flowbot") {
		<script src="/static/js/chatagent-permissions.js"></script>
		@partials.PageHeader("Chat Agent Permissions", "Edit OpenCode-style permission rules stored for your user account.") {
			<a href="/service/web/agent-sessions" class="btn btn-ghost btn-sm">← Back to Sessions</a>
		}
		<div class="flowbot-surface">
			<div class="card-body">
				if data.Errors["_form"] != "" {
					<div class="alert alert-error text-sm" data-testid="chatagent-permissions-form-error">
						<span>{ data.Errors["_form"] }</span>
					</div>
				}
				@partials.ChatAgentPermissionsForm(data)
			</div>
		</div>
	}
}
