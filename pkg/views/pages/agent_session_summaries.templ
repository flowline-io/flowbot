package pages

import (
	"github.com/flowline-io/flowbot/pkg/types/model"
	"github.com/flowline-io/flowbot/pkg/views/layout"
	"github.com/flowline-io/flowbot/pkg/views/partials"
)

templ AgentSessionSummariesPage(items []model.AgentSessionSummary, q string) {
	@layout.Base("Session Summaries — Flowbot") {
		@partials.PageHeader("Session Summaries", "Archive-generated summaries searchable via search_session_summaries") {
			<form class="inline-flex items-center gap-2 m-0"
				hx-get="/service/web/agent-session-summaries/list"
				hx-target="#agent-session-summaries-table"
				hx-swap="outerHTML"
				hx-trigger="submit, keyup changed delay:300ms from:input">
				<input type="search" name="q" value={ q }
					placeholder="Filter title or summary"
					data-testid="agent-session-summaries-filter"
					class="input input-bordered input-sm w-48 md:w-64"/>
				<button type="submit" data-testid="agent-session-summaries-refresh" class="btn btn-ghost btn-sm">
					Refresh
					@partials.HtmxIndicator()
				</button>
			</form>
		}
		@partials.AgentSessionSummariesTable(items, q)
	}
}
