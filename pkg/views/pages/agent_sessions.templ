package pages

import (
	"github.com/flowline-io/flowbot/pkg/types/model"
	"github.com/flowline-io/flowbot/pkg/views/layout"
	"github.com/flowline-io/flowbot/pkg/views/partials"
)

templ AgentSessionsPage(items []model.AgentSession, nextCursor string) {
	@layout.Base("Agent Sessions — Flowbot") {
		@partials.PageHeader("Agent Sessions", "") {
			<button hx-get="/service/web/agent-sessions/list"
				hx-target="#agent-sessions-table"
				hx-swap="outerHTML"
				data-testid="agent-sessions-refresh"
				class="btn btn-ghost btn-sm">
				Refresh
				@partials.HtmxIndicator()
			</button>
		}
		@partials.AgentSessionTable(items, nextCursor)
	}
}
