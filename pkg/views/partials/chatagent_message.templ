package partials

import "github.com/flowline-io/flowbot/pkg/types/model"

templ ChatAgentMessage(msg model.AgentChatMessage, streaming bool) {
	if msg.Kind == "tool" || msg.Role == "tool" {
		@ChatAgentToolMessage(msg)
	} else if msg.Kind == "thinking" {
		<details class="chatagent-thinking opacity-90" data-role="thinking" data-testid="chatagent-message-thinking">
			<summary class="chatagent-thinking-summary cursor-pointer text-xs text-base-content/50 select-none">
				Thinking
				if msg.ThinkingDurationMs > 0 {
					<span class="chatagent-duration text-base-content/40" data-testid="chatagent-duration">· { ChatAgentDurationLabel(msg.ThinkingDurationMs) }</span>
				}
			</summary>
			if msg.HTML != "" {
				<div class="chatagent-thinking-body chatagent-markdown markdown-body mt-2" data-testid="chatagent-message-body">
					// msg.HTML comes from FormatChatAgentMessageHTML / RenderChatAgentMarkdownHTML (sanitized).
					@templ.Raw(msg.HTML)
				</div>
			} else {
				<div class="chatagent-thinking-body mt-2" data-testid="chatagent-message-body">{ msg.Text }</div>
			}
		</details>
	} else {
		<div
			class={ chatAgentMessageClass(msg.Role, streaming) }
			data-role={ msg.Role }
			data-testid={ "chatagent-message-" + msg.Role }>
			if msg.Role == "assistant" && msg.HTML != "" && !streaming {
				<div class="chat-bubble bg-base-100 border border-base-300 chatagent-markdown markdown-body text-sm max-w-[92%]" data-testid="chatagent-message-body">
					// msg.HTML comes from FormatChatAgentMessageHTML / RenderChatAgentMarkdownHTML (sanitized).
					@templ.Raw(msg.HTML)
					@ChatAgentAssistantMeta(msg, !streaming)
				</div>
			} else if msg.Role == "user" {
				<div class="chat-bubble bg-primary text-primary-content whitespace-pre-wrap text-sm max-w-[92%]" data-testid="chatagent-message-body">
					if len(msg.Attachments) > 0 {
						<div class="chatagent-message-attachments" data-testid="chatagent-message-attachments">
							for _, att := range msg.Attachments {
								if att.Kind == "image" && att.URL != "" {
									<img
										src={ att.URL }
										alt=""
										class="chatagent-message-attach-img"
										loading="lazy"
										data-testid="chatagent-message-attach-img"/>
								} else {
									<span class="chatagent-message-attach-file">[{ att.Kind }] { att.FileID }</span>
								}
							}
						</div>
					}
					if msg.Text != "" {
						<div class="chatagent-message-text">{ msg.Text }</div>
					}
					if msg.TurnDurationMs > 0 || msg.RunDurationMs > 0 {
						@ChatAgentDurationFooter(msg)
					}
				</div>
			} else {
				<div class="chat-bubble bg-base-100 border border-base-300 whitespace-pre-wrap text-sm max-w-[92%]" data-testid="chatagent-message-body">
					if msg.Text != "" {
						{ msg.Text }
					}
					if msg.Role == "assistant" {
						@ChatAgentAssistantMeta(msg, !streaming)
					} else if msg.TurnDurationMs > 0 || msg.RunDurationMs > 0 {
						@ChatAgentDurationFooter(msg)
					}
				</div>
			}
		</div>
	}
}

// ChatAgentAssistantMeta renders duration (left) and copy-markdown (right) under assistant content.
templ ChatAgentAssistantMeta(msg model.AgentChatMessage, showCopy bool) {
	if msg.TurnDurationMs > 0 || msg.RunDurationMs > 0 || (showCopy && msg.Text != "") {
		<div class="chatagent-message-meta" data-testid="chatagent-message-meta">
			if msg.TurnDurationMs > 0 || msg.RunDurationMs > 0 {
				@ChatAgentDurationFooter(msg)
			} else {
				<span class="chatagent-message-meta-spacer"></span>
			}
			if showCopy && msg.Text != "" {
				@ChatAgentCopyMarkdownButton(msg.Text)
			}
		</div>
	}
}

// ChatAgentDurationFooter shows turn/total timing inside the assistant meta row.
templ ChatAgentDurationFooter(msg model.AgentChatMessage) {
	<div class="chatagent-duration text-xs text-base-content/50" data-testid="chatagent-message-duration">
		if msg.TurnDurationMs > 0 {
			<span>Turn { ChatAgentDurationLabel(msg.TurnDurationMs) }</span>
		}
		if msg.TurnDurationMs > 0 && msg.RunDurationMs > 0 {
			<span> · </span>
		}
		if msg.RunDurationMs > 0 {
			<span>Total { ChatAgentDurationLabel(msg.RunDurationMs) }</span>
		}
	</div>
}

// ChatAgentCopyMarkdownButton copies the assistant reply as raw markdown.
templ ChatAgentCopyMarkdownButton(markdown string) {
	<button
		type="button"
		class="btn btn-ghost btn-xs btn-square chatagent-copy-md"
		title="Copy markdown"
		aria-label="Copy markdown"
		data-testid="chatagent-copy-md"
		data-clip-copy
		data-clip-markdown={ markdown }
	>
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3" aria-hidden="true">
			<path d="M5 6.5A1.5 1.5 0 0 1 6.5 5h6A1.5 1.5 0 0 1 14 6.5v6a1.5 1.5 0 0 1-1.5 1.5h-6A1.5 1.5 0 0 1 5 12.5v-6Z"></path>
			<path d="M3.5 2A1.5 1.5 0 0 0 2 3.5v6A1.5 1.5 0 0 0 3.5 11V6.5a3 3 0 0 1 3-3H11A1.5 1.5 0 0 0 9.5 2h-6Z"></path>
		</svg>
	</button>
}

func chatAgentMessageClass(role string, streaming bool) string {
	base := "chat "
	switch role {
	case "user":
		base += "chat-end "
	default:
		base += "chat-start "
	}
	if streaming {
		base += "opacity-80"
	}
	return base
}
