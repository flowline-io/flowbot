package partials

// ChatAgentSettingsCluster renders compact model and thinking selects for the
// bottom-left corner of the agents composer and thread input dialogs.
templ ChatAgentSettingsCluster(
	modelID string,
	thinkingID string,
	models []SelectableModelOption,
	selectedModel string,
	selectedThinking string,
	disabled bool,
) {
	<div
		class="chatagent-settings"
		data-testid="chatagent-settings"
		data-selected-multimodal={ chatAgentMultimodalAttr(chatAgentModelMultimodal(models, selectedModel)) }>
		if len(models) > 1 {
			<select
				id={ modelID }
				class="chatagent-settings-select"
				disabled?={ disabled }
				data-session-model={ selectedModel }
				data-testid={ modelID }
				aria-label="Model">
				for _, m := range models {
					if selectedModel != "" && m.ID == selectedModel {
						<option value={ m.ID } data-multimodal={ chatAgentMultimodalAttr(m.Multimodal) } selected>{ m.Name }</option>
					} else {
						<option value={ m.ID } data-multimodal={ chatAgentMultimodalAttr(m.Multimodal) }>{ m.Name }</option>
					}
				}
			</select>
			<span class="chatagent-settings-sep" aria-hidden="true">·</span>
		}
		<select
			id={ thinkingID }
			class="chatagent-settings-select"
			disabled?={ disabled }
			data-session-thinking={ selectedThinking }
			data-testid={ thinkingID }
			aria-label="Thinking level">
			@chatAgentThinkingOption("default", "Default", selectedThinking)
			@chatAgentThinkingOption("off", "Off", selectedThinking)
			@chatAgentThinkingOption("low", "Low", selectedThinking)
			@chatAgentThinkingOption("medium", "Medium", selectedThinking)
			@chatAgentThinkingOption("high", "High", selectedThinking)
		</select>
	</div>
}

// ChatAgentAttachButton renders the circle-plus control used to attach media.
templ ChatAgentAttachButton(id string, hidden bool, disabled bool) {
	<button
		type="button"
		id={ id }
		class={ "chatagent-attach-btn", templ.KV("hidden", hidden) }
		disabled?={ disabled }
		data-testid={ id }
		title="Attach media"
		aria-label="Attach media">
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" class="chatagent-attach-icon" aria-hidden="true">
			<circle cx="10" cy="10" r="7.25" stroke="currentColor" stroke-width="1.5"></circle>
			<path stroke="currentColor" stroke-width="1.5" stroke-linecap="round" d="M10 6.75v6.5M6.75 10h6.5"></path>
		</svg>
	</button>
}

templ chatAgentThinkingOption(value, label, selectedThinking string) {
	if chatAgentThinkingSelected(value, selectedThinking) {
		<option value={ value } selected>{ label }</option>
	} else {
		<option value={ value }>{ label }</option>
	}
}
