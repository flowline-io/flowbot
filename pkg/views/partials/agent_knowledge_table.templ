package partials

import "github.com/flowline-io/flowbot/pkg/types/model"

templ AgentKnowledgeTable(items []model.AgentKnowledge, q string) {
	<div class="flowbot-surface" id="agent-knowledge-table" data-testid="agent-knowledge-table">
		<div class="overflow-x-auto">
			<table class="table flowbot-table-pin">
				<thead>
				<tr>
					<th class="text-xs text-base-content/55">Path</th>
					<th class="text-xs text-base-content/55">Title</th>
					<th class="text-xs text-base-content/55">Tags</th>
					<th class="text-xs text-base-content/55">Summary</th>
					<th class="text-xs text-base-content/55">Updated</th>
					<th class="text-xs text-base-content/55">Actions</th>
				</tr>
				</thead>
				<tbody id="agent-knowledge-rows">
				for _, item := range items {
					@AgentKnowledgeRow(item)
				}
				if len(items) == 0 {
					<tr id="agent-knowledge-empty">
						<td colspan="6" class="p-0">
							@EmptyStateHXCTA(
								"No knowledge documents yet",
								"Add markdown docs for the agent to search and read.",
								"/service/web/agent-knowledge/new",
								"#agent-knowledge-rows",
								"afterbegin",
								"Create document",
							)
						</td>
					</tr>
				}
				</tbody>
			</table>
		</div>
	</div>
}
