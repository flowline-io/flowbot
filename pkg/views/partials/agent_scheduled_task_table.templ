package partials

import (
	"github.com/flowline-io/flowbot/pkg/types/model"
)

templ AgentScheduledTaskTable(items []model.AgentScheduledTask) {
	<div class="flowbot-surface" id="agent-scheduled-tasks-table" data-testid="agent-scheduled-tasks-table">
		<div class="overflow-x-auto">
			<table class="table flowbot-table-pin">
				<thead>
					<tr>
						<th class="text-xs text-base-content/55">Name</th>
						<th class="text-xs text-base-content/55">Task ID</th>
						<th class="text-xs text-base-content/55">Kind</th>
						<th class="text-xs text-base-content/55">Schedule</th>
						<th class="text-xs text-base-content/55 text-center">State</th>
						<th class="text-xs text-base-content/55">Next Run</th>
						<th class="text-xs text-base-content/55">Last Run</th>
						<th class="text-xs text-base-content/55">Updated</th>
					</tr>
				</thead>
				<tbody id="agent-scheduled-tasks-rows">
					for _, item := range items {
						@AgentScheduledTaskRow(item)
					}
					if len(items) == 0 {
						<tr id="agent-scheduled-tasks-empty">
							<td colspan="8" class="p-0">
								@EmptyStateCTA(
									"No scheduled tasks yet",
									"Ask an agent to schedule recurring work.",
									"/service/web/agents",
									"Open Agents",
								)
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	</div>
}
