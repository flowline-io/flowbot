package partials

templ ChatAgentSessionsDrawer(endpoints ChatAgentEndpoints) {
	<dialog
		id="chatagent-sessions-drawer"
		class="modal items-start justify-start p-0"
		data-testid="chatagent-sessions-drawer">
		<div class="modal-box chatagent-sessions-drawer-panel h-dvh max-h-dvh w-full max-w-sm rounded-none m-0 p-0 flex flex-col">
			<div class="flex items-center justify-between gap-2 px-4 py-3 border-b border-base-300 shrink-0">
				<h2 class="text-base font-semibold tracking-tight m-0">Sessions</h2>
				<form method="dialog">
					<button type="submit" class="btn btn-ghost btn-sm btn-square" aria-label="Close sessions" data-testid="chatagent-sessions-drawer-close">
						&times;
					</button>
				</form>
			</div>
			<div
				id="chatagent-sessions-drawer-body"
				class="flex-1 min-h-0 overflow-y-auto px-3 py-3"
				data-testid="chatagent-sessions-drawer-body"
				hx-get={ templ.URL(ChatAgentSessionListURL(endpoints, "")) }
				hx-trigger="intersect once"
				hx-swap="innerHTML">
				@PanelSkeleton()
			</div>
		</div>
		<form method="dialog" class="modal-backdrop">
			<button type="submit">close</button>
		</form>
	</dialog>
}
