package partials

templ AgentMemoryModal() {
	<div
		x-show="memoryModalOpen"
		x-cloak
		class="fixed inset-0 z-60 flex items-center justify-center p-4"
		data-testid="agent-memory-modal">
		<div class="absolute inset-0 bg-black/30" @click="closeMemoryModal"></div>
		<div class="relative bg-base-100 rounded-box shadow-xl w-full max-w-lg border border-base-300" role="dialog" aria-label="Memory Notes">
			<div class="flex items-start justify-between px-5 pt-5 pb-3 border-b border-base-300">
				<div>
					<h3 class="text-lg font-semibold text-base-content">Memory Notes</h3>
					<p class="text-sm text-base-content/60">View and edit memory-tool files that agents use</p>
				</div>
				<button type="button" class="btn btn-ghost btn-sm btn-circle" @click="closeMemoryModal" aria-label="Close memory notes" data-testid="agent-memory-close">&times;</button>
			</div>
			<div class="px-5 py-4 space-y-4">
				<label class="form-control w-full">
					<span class="label-text mb-1">File</span>
					<select
						class="select select-bordered w-full"
						x-model="memorySelectedFile"
						@change="loadMemoryContent()"
						data-testid="agent-memory-file-select">
						<template x-for="file in memoryFiles" :key="file">
							<option :value="file" x-text="file"></option>
						</template>
					</select>
				</label>
				<label class="form-control w-full">
					<span class="label-text mb-1">Content</span>
					<textarea
						class="textarea textarea-bordered w-full min-h-48 font-mono text-sm"
						x-model="memoryContent"
						data-testid="agent-memory-content"></textarea>
				</label>
				<p class="text-sm text-error hidden" :class="{ 'hidden': !memoryError, 'block': memoryError }" x-text="memoryError" data-testid="agent-memory-error"></p>
			</div>
			<div class="flex justify-end gap-2 px-5 py-4 border-t border-base-300">
				<button type="button" class="btn btn-ghost btn-sm" @click="closeMemoryModal" data-testid="agent-memory-cancel">Cancel</button>
				<button type="button" class="btn btn-primary btn-sm" @click="saveMemoryContent()" :disabled="memorySaving" data-testid="agent-memory-save">
					<span x-show="!memorySaving">Save</span>
					<span x-show="memorySaving">Saving...</span>
				</button>
			</div>
		</div>
	</div>
}
