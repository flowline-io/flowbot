package partials

templ AgentSessionEntryPayload(payloadJSON string) {
	<td colspan="4" class="p-0">
		<div class="p-3">
			<details open>
				<summary class="text-sm font-semibold cursor-pointer">Payload</summary>
				if payloadJSON != "" {
					<pre class="bg-base-200 rounded p-2 text-xs font-mono overflow-x-auto max-h-96 mt-1">{ payloadJSON }</pre>
				} else {
					<p class="text-sm text-base-content/50 mt-1">No payload.</p>
				}
			</details>
		</div>
	</td>
}
