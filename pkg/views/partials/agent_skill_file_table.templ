package partials

import "github.com/flowline-io/flowbot/pkg/types/model"

templ AgentSkillFileTable(skill model.AgentSkill, files []model.AgentSkillFile) {
	<div id={ agentSkillFilesContainerID(skill) } class="md:col-span-2 border-t border-base-300 pt-4 mt-2">
		<div class="flex items-center justify-between mb-2">
			<span class="label-text font-medium">Skill Files</span>
			<button type="button"
				hx-get={ agentSkillFileNewURL(skill) }
				hx-target={ "#" + agentSkillFilesContainerID(skill) }
				hx-swap="innerHTML"
				data-testid="agent-skill-file-add"
				class="btn btn-ghost btn-xs text-primary">
				Add File
			</button>
		</div>
		if len(files) == 0 {
			<p class="text-sm text-base-content/50" data-testid="agent-skill-files-empty">No auxiliary files yet.</p>
		} else {
			<div class="flex flex-col gap-2" data-testid="agent-skill-files-list">
				for _, file := range files {
					@AgentSkillFileRow(skill, file)
				}
			</div>
		}
	</div>
}
