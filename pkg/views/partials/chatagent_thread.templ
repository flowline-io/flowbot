package partials

import "github.com/flowline-io/flowbot/pkg/types/model"

templ ChatAgentThread(session model.AgentSession, messages []model.AgentChatMessage, todos []model.AgentTodo, endpoints ChatAgentEndpoints, pending *ChatAgentPendingConfirm) {
	<div
		class="chatagent-thread flex flex-col flex-1 min-h-0"
		data-chatagent-root="thread"
		data-session-id={ session.Flag }
		data-messages-url={ endpoints.MessagesURL }
		if endpoints.MediaURL != "" {
			data-media-url={ endpoints.MediaURL }
		}
		data-cancel-url={ endpoints.CancelURL }
		data-close-url={ endpoints.CloseURL }
		data-confirm-url={ endpoints.ConfirmURL }
		data-events-url={ endpoints.EventsURL }
		data-render-markdown-url={ endpoints.RenderMarkdownURL }
		data-context-url={ endpoints.ContextURL }
		data-default-model={ endpoints.DefaultModel }
		data-session-model={ session.Model }
		data-session-thinking={ session.ThinkingLevel }
		if endpoints.SettingsURL != "" {
			data-settings-url={ endpoints.SettingsURL }
		}
		if endpoints.TodosURL != "" {
			data-todos-url={ endpoints.TodosURL }
		}
		data-testid="chatagent-thread">
		<header class="chatagent-thread-header shrink-0 px-1 mb-3 sm:mb-5" data-testid="chatagent-thread-header">
			<div class="flex items-start gap-2">
				<div class="min-w-0 flex-1">
					if session.Title != "" {
						<h1 class="chatagent-thread-title text-lg sm:text-2xl font-semibold tracking-tight text-base-content" data-testid="chatagent-thread-title">{ session.Title }</h1>
						<p class="hidden lg:flex font-mono text-xs sm:text-sm text-base-content/55 mt-0.5" data-testid="chatagent-thread-session-id">{ session.Flag }</p>
					} else {
						<h1 class="chatagent-thread-title text-lg sm:text-2xl font-semibold tracking-tight font-mono text-base-content" data-testid="chatagent-thread-title">{ session.Flag }</h1>
					}
					<p id="chatagent-session-model-label" class="text-xs text-base-content/50 mt-0.5 truncate" data-testid="chatagent-session-model-label">
						{ chatAgentSessionSettingsLabel(session, endpoints.DefaultModel) }
					</p>
				</div>
				<div class="hidden lg:flex flex-wrap justify-end gap-1 shrink-0 pt-0.5" data-testid="chatagent-header-actions-desktop">
					if session.State == "Active" && endpoints.CloseURL != "" {
						<button
							type="button"
							id="chatagent-close-session"
							class="btn btn-ghost btn-sm text-error"
							data-chatagent-close
							data-testid="chatagent-close-session">Close session</button>
					}
					if endpoints.InspectURL != "" {
						<a href={ templ.URL(endpoints.InspectURL) } class="btn btn-ghost btn-sm" data-testid="chatagent-inspect">Inspect entries</a>
					}
					<a href="/service/web/agents" class="btn btn-ghost btn-sm" data-testid="chatagent-back">Back to Agents</a>
				</div>
				<div class="flex lg:hidden items-center gap-0.5 shrink-0 pt-0.5">
					if endpoints.ListURL != "" {
						<button
							type="button"
							class="btn btn-ghost btn-sm btn-square"
							aria-label="Sessions"
							title="Sessions"
							data-testid="chatagent-sessions-open"
							onclick="document.getElementById('chatagent-sessions-drawer').showModal()">
							<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M8 6h13"></path>
								<path d="M8 12h13"></path>
								<path d="M8 18h13"></path>
								<path d="M3 6h.01"></path>
								<path d="M3 12h.01"></path>
								<path d="M3 18h.01"></path>
							</svg>
						</button>
					}
					<button
						type="button"
						class="btn btn-ghost btn-sm btn-square"
						aria-label="Session actions"
						data-testid="chatagent-header-menu"
						onclick="document.getElementById('chatagent-header-actions-dialog').showModal()">
						<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<circle cx="12" cy="5" r="1"></circle>
							<circle cx="12" cy="12" r="1"></circle>
							<circle cx="12" cy="19" r="1"></circle>
						</svg>
					</button>
				</div>
			</div>
		</header>
		<dialog
			id="chatagent-header-actions-dialog"
			class="modal lg:hidden"
			data-testid="chatagent-header-menu-panel">
			<div class="modal-box max-w-xs p-2">
				<ul class="menu menu-sm w-full p-0">
					if session.State == "Active" && endpoints.CloseURL != "" {
						<li>
							<button
								type="button"
								class="text-error"
								data-chatagent-close
								data-testid="chatagent-close-session-mobile">Close session</button>
						</li>
					}
					if endpoints.InspectURL != "" {
						<li>
							<a href={ templ.URL(endpoints.InspectURL) } data-testid="chatagent-inspect-mobile">Inspect entries</a>
						</li>
					}
					<li>
						<a href="/service/web/agents" data-testid="chatagent-back-mobile">Back to Agents</a>
					</li>
				</ul>
			</div>
			<form method="dialog" class="modal-backdrop">
				<button type="submit">close</button>
			</form>
		</dialog>
		if endpoints.ListURL != "" {
			@ChatAgentSessionsDrawer(endpoints)
		}
		<div
			id="chatagent-status-toast"
			class="chatagent-status-toast hidden shrink-0 mx-1 mb-3 alert py-2 text-sm"
			data-testid="chatagent-status-toast"></div>
		if len(todos) > 0 {
			@ChatAgentTodosPanel(todos)
		}
		<div class="chatagent-messages-wrap relative flex-1 min-h-0 flex flex-col">
			<div id="chatagent-messages" class="flex-1 min-h-0 space-y-4 px-1 pr-1 pb-4" data-testid="chatagent-messages">
				if pending != nil {
					<div class="chatagent-run-waiting text-sm text-base-content/60 px-1 py-2" data-testid="chatagent-run-waiting">
						Waiting for tool approval. The rest of this turn appears after it finishes.
					</div>
				}
				for _, msg := range messages {
					@ChatAgentMessage(msg, false)
				}
			</div>
			<button
				type="button"
				id="chatagent-jump-bottom"
				class="chatagent-jump-bottom hidden"
				data-testid="chatagent-jump-bottom"
				aria-label="Jump to bottom">
				Jump to bottom
			</button>
		</div>
		@ChatAgentApprovalPanel(session.Flag, endpoints, pending)
		<div class="chatagent-input-bar shrink-0 border-t border-base-300 bg-base-100 px-1 pt-3 pb-4" data-testid="chatagent-input-bar">
			<div class="chatagent-input-stack">
				@ChatAgentContextPopover(endpoints)
				<div class="flex items-end gap-2">
					<div class="chatagent-input-wrap flex-1 min-w-0">
						<div id="chatagent-pending-attachments" class="chatagent-pending-attachments empty:hidden" data-testid="chatagent-pending-attachments"></div>
						<textarea
							id="chatagent-followup-input"
							class="chatagent-followup-textarea w-full min-h-12 max-h-40 resize-y leading-normal"
							placeholder="Add follow-up... (Enter to send, Shift+Enter for newline; paste image to attach)"
							rows="2"
							data-testid="chatagent-followup-input"></textarea>
						<div class="chatagent-input-footer">
							<div class="flex items-center gap-1 min-w-0">
								<input type="file" id="chatagent-media-input" class="hidden" accept="image/jpeg,image/png,image/webp,image/gif,audio/*,video/mp4,video/webm" data-testid="chatagent-media-input" multiple />
								@ChatAgentAttachButton(
									"chatagent-attach-media",
									!chatAgentModelMultimodal(endpoints.SelectableModels, chatAgentSelectedModel(session.Model, endpoints.DefaultModel)),
									false,
								)
								if endpoints.SettingsURL != "" {
									@ChatAgentSettingsCluster(
										"chatagent-thread-model",
										"chatagent-thread-thinking",
										endpoints.SelectableModels,
										chatAgentSelectedModel(session.Model, endpoints.DefaultModel),
										session.ThinkingLevel,
										false,
									)
								}
							</div>
							@ChatAgentContextRing()
						</div>
					</div>
					<button type="button" id="chatagent-cancel-run" class="btn btn-ghost btn-sm hidden shrink-0" data-testid="chatagent-cancel-run">Cancel</button>
				</div>
			</div>
			<p class="text-xs text-error hidden mt-2" id="chatagent-thread-error" data-testid="chatagent-thread-error"></p>
		</div>
	</div>
}
