package partials

import "github.com/flowline-io/flowbot/pkg/types/model"

templ ChatAgentThread(session model.AgentSession, messages []model.AgentChatMessage, todos []model.AgentTodo, endpoints ChatAgentEndpoints, pending *ChatAgentPendingConfirm) {
	<div
		class="chatagent-thread flex flex-col flex-1 min-h-0"
		data-chatagent-root="thread"
		data-session-id={ session.Flag }
		data-messages-url={ endpoints.MessagesURL }
		data-cancel-url={ endpoints.CancelURL }
		data-close-url={ endpoints.CloseURL }
		data-confirm-url={ endpoints.ConfirmURL }
		data-events-url={ endpoints.EventsURL }
		data-render-markdown-url={ endpoints.RenderMarkdownURL }
		data-context-url={ endpoints.ContextURL }
		data-default-model={ endpoints.DefaultModel }
		data-session-model={ session.Model }
		data-session-thinking={ session.ThinkingLevel }
		if endpoints.SettingsURL != "" {
			data-settings-url={ endpoints.SettingsURL }
		}
		if endpoints.TodosURL != "" {
			data-todos-url={ endpoints.TodosURL }
		}
		data-testid="chatagent-thread">
		<div class="flex items-center justify-between mb-5 gap-2 shrink-0 px-1">
			<div>
				if session.Title != "" {
					<h1 class="text-2xl font-semibold tracking-tight text-base-content">{ session.Title }</h1>
					<p class="font-mono text-sm text-base-content/60">{ session.Flag }</p>
				} else {
					<h1 class="text-2xl font-semibold tracking-tight font-mono text-base-content">{ session.Flag }</h1>
				}
				<p id="chatagent-session-model-label" class="text-xs text-base-content/50 mt-0.5" data-testid="chatagent-session-model-label">
					{ chatAgentSessionSettingsLabel(session, endpoints.DefaultModel) }
				</p>
			</div>
			<div class="flex gap-2">
				if session.State == "Active" && endpoints.CloseURL != "" {
					<button
						type="button"
						id="chatagent-close-session"
						class="btn btn-ghost btn-sm text-error"
						data-testid="chatagent-close-session">Close session</button>
				}
				if endpoints.InspectURL != "" {
					<a href={ templ.URL(endpoints.InspectURL) } class="btn btn-ghost btn-sm" data-testid="chatagent-inspect">Inspect entries</a>
				}
				<a href="/service/web/agents" class="btn btn-ghost btn-sm" data-testid="chatagent-back">Back to Agents</a>
			</div>
		</div>
		<div
			id="chatagent-status-toast"
			class="chatagent-status-toast hidden shrink-0 mx-1 mb-3 alert py-2 text-sm"
			data-testid="chatagent-status-toast"></div>
		if len(todos) > 0 {
			@ChatAgentTodosPanel(todos)
		}
		<div class="chatagent-messages-wrap relative flex-1 min-h-0 flex flex-col">
			<div id="chatagent-messages" class="flex-1 min-h-0 space-y-4 px-1 pr-1 pb-4" data-testid="chatagent-messages">
				if pending != nil {
					<div class="chatagent-run-waiting text-sm text-base-content/60 px-1 py-2" data-testid="chatagent-run-waiting">
						Waiting for tool approval. The rest of this turn appears after it finishes.
					</div>
				}
				for _, msg := range messages {
					@ChatAgentMessage(msg, false)
				}
			</div>
			<button
				type="button"
				id="chatagent-jump-bottom"
				class="chatagent-jump-bottom hidden"
				data-testid="chatagent-jump-bottom"
				aria-label="Jump to bottom">
				Jump to bottom
			</button>
		</div>
		@ChatAgentApprovalPanel(session.Flag, endpoints, pending)
		<div class="chatagent-input-bar shrink-0 border-t border-base-300 bg-base-100 px-1 pt-3 pb-4" data-testid="chatagent-input-bar">
			<div class="chatagent-input-stack">
				@ChatAgentContextPopover(endpoints)
				<div class="flex items-end gap-2">
					<div class="chatagent-input-wrap flex-1 min-w-0">
						<textarea
							id="chatagent-followup-input"
							class="chatagent-followup-textarea w-full min-h-12 max-h-40 resize-y leading-normal"
							placeholder="Add follow-up... (Enter to send, Shift+Enter for newline)"
							rows="2"
							data-testid="chatagent-followup-input"></textarea>
						<div class="chatagent-input-footer">
							if endpoints.SettingsURL != "" {
								@ChatAgentSettingsCluster(
									"chatagent-thread-model",
									"chatagent-thread-thinking",
									endpoints.SelectableModels,
									chatAgentSelectedModel(session.Model, endpoints.DefaultModel),
									session.ThinkingLevel,
									false,
								)
							} else {
								<span></span>
							}
							@ChatAgentContextRing()
						</div>
					</div>
					<button type="button" id="chatagent-cancel-run" class="btn btn-ghost btn-sm hidden shrink-0" data-testid="chatagent-cancel-run">Cancel</button>
				</div>
			</div>
			<p class="text-xs text-error hidden mt-2" id="chatagent-thread-error" data-testid="chatagent-thread-error"></p>
		</div>
	</div>
}
