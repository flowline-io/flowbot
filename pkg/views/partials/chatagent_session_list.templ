package partials

import (
	"time"

	"github.com/flowline-io/flowbot/pkg/types/model"
)

templ ChatAgentComposer(endpoints ChatAgentEndpoints, placeholder string, disabled bool) {
	<div
		class="agents-composer mb-8"
		data-chatagent-root="composer"
		data-create-url={ endpoints.CreateURL }
		data-detail-url-template={ endpoints.DetailURLTemplate }
		data-default-model={ endpoints.DefaultModel }
		data-testid="chatagent-composer">
		if disabled {
			<div class="alert alert-warning text-sm mb-3" data-testid="chatagent-disabled">Chat agent is not enabled. Configure chat_agent.chat_model in flowbot.yaml.</div>
		}
		<div class="agents-composer-box">
			<div
				id="chatagent-composer-pending"
				class="chatagent-pending-attachments empty:hidden"
				data-testid="chatagent-composer-pending"></div>
			<textarea
				id="chatagent-composer-input"
				class="agents-composer-input"
				placeholder={ placeholder }
				disabled?={ disabled }
				rows="3"
				data-testid="chatagent-composer-input"></textarea>
			<div class="agents-composer-toolbar">
				<div class="agents-composer-toolbar-left">
					<input
						type="file"
						id="chatagent-composer-media-input"
						class="hidden"
						accept="image/jpeg,image/png,image/webp,image/gif,audio/*,video/mp4,video/webm"
						data-testid="chatagent-composer-media-input"
						multiple
						disabled?={ disabled }/>
					@ChatAgentAttachButton(
						"chatagent-composer-attach",
						!chatAgentModelMultimodal(endpoints.SelectableModels, endpoints.DefaultModel),
						disabled,
					)
					@ChatAgentSettingsCluster(
						"chatagent-composer-model",
						"chatagent-composer-thinking",
						endpoints.SelectableModels,
						endpoints.DefaultModel,
						"",
						disabled,
					)
				</div>
				<button
					type="button"
					id="chatagent-composer-start"
					class="agents-composer-send"
					disabled?={ disabled }
					aria-label="Start agent"
					data-testid="chatagent-composer-start">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true">
						<path fill-rule="evenodd" d="M10 17a.75.75 0 01-.75-.75V5.612L5.29 9.77a.75.75 0 01-1.08-1.04l5.25-5.5a.75.75 0 011.08 0l5.25 5.5a.75.75 0 11-1.08 1.04l-3.96-4.158V16.25A.75.75 0 0110 17z" clip-rule="evenodd"></path>
					</svg>
				</button>
			</div>
		</div>
		<p class="text-xs text-error mt-2 hidden" id="chatagent-composer-error" data-testid="chatagent-composer-error"></p>
	</div>
}

templ ChatAgentSessionRow(item model.AgentSession, endpoints ChatAgentEndpoints) {
	<div
		class={ "agents-session-row", templ.KV("agents-session-row-pinned", item.Pinned) }
		data-testid={ "chatagent-session-row-" + item.Flag }
		data-session-link>
		<a
			href={ templ.URL(ChatAgentDetailURL(endpoints.DetailURLTemplate, item.Flag)) }
			class="agents-session-main"
			data-testid="chatagent-session-link">
			<div class={ chatAgentSessionThumbClass(chatAgentSessionDisplayState(item)) } aria-hidden="true">
				<span class={ chatAgentSessionBadgeClass(chatAgentSessionDisplayState(item)) }>
					if item.Activity == "needs_approval" {
						Needs approval
					} else if item.Activity == "running" {
						Running
					} else if item.State == "Active" {
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3" aria-hidden="true">
							<path fill-rule="evenodd" d="M8 1.5a6.5 6.5 0 100 13 6.5 6.5 0 000-13zM0 8a8 8 0 1116 0A8 8 0 010 8zm11.78-2.78a.75.75 0 00-1.06-1.06L6.75 8.19 5.28 6.72a.75.75 0 00-1.06 1.06l2 2a.75.75 0 001.06 0l4.5-4.5z" clip-rule="evenodd"></path>
						</svg>
						Active
					} else {
						{ item.State }
					}
				</span>
			</div>
			<div class="agents-session-body">
				<div class="agents-session-title-row">
					<div class="agents-session-title">{ ChatAgentSessionTitle(item) }</div>
					if item.Pinned {
						<span class="agents-session-pin-mark" aria-label="Pinned" data-testid="chatagent-session-pinned">Pinned</span>
					}
				</div>
				if preview := TruncateChatAgentSessionPreview(item.Preview, 96); preview != "" {
					<div class="agents-session-preview" data-testid="chatagent-session-preview">{ preview }</div>
				}
				<div class="agents-session-meta">
					<span>{ FormatChatAgentRelativeTime(item.UpdatedAt) }</span>
					if item.TotalDurationMs > 0 {
						<span class="chatagent-duration" data-testid="chatagent-session-duration">· Total { ChatAgentDurationLabel(item.TotalDurationMs) }</span>
					}
				</div>
				if item.TodoSummary != nil && item.TodoSummary.Total > 0 {
					<div class="agents-session-todos" data-testid="chatagent-session-todos">
						<span class="agents-session-todos-progress" aria-hidden="true">
							<span class="agents-session-todos-progress-fill" style={ "width: " + chatAgentTodoSummaryProgressWidth(*item.TodoSummary) }></span>
						</span>
						<span class="agents-session-todos-line" data-testid="chatagent-session-todos-line">{ chatAgentSessionTodoLineLabel(*item.TodoSummary) }</span>
					</div>
				}
			</div>
		</a>
		<div class="agents-session-actions">
			if item.Pinned {
				<button
					type="button"
					class="btn btn-ghost btn-xs"
					hx-delete={ templ.URL(ChatAgentListActionURL(endpoints.PinURLTemplate, item.Flag, endpoints.Filter)) }
					hx-target="#chatagent-session-list"
					hx-swap="outerHTML"
					data-testid="chatagent-session-unpin">Unpin</button>
			} else {
				<button
					type="button"
					class="btn btn-ghost btn-xs"
					hx-post={ templ.URL(ChatAgentListActionURL(endpoints.PinURLTemplate, item.Flag, endpoints.Filter)) }
					hx-target="#chatagent-session-list"
					hx-swap="outerHTML"
					data-testid="chatagent-session-pin">Pin</button>
			}
			if item.Archived {
				<button
					type="button"
					class="btn btn-ghost btn-xs"
					hx-delete={ templ.URL(ChatAgentListActionURL(endpoints.ArchiveURLTemplate, item.Flag, endpoints.Filter)) }
					hx-target="#chatagent-session-list"
					hx-swap="outerHTML"
					data-testid="chatagent-session-unarchive">Unarchive</button>
			} else {
				<button
					type="button"
					class="btn btn-ghost btn-xs"
					hx-post={ templ.URL(ChatAgentListActionURL(endpoints.ArchiveURLTemplate, item.Flag, endpoints.Filter)) }
					hx-target="#chatagent-session-list"
					hx-swap="outerHTML"
					data-testid="chatagent-session-archive">Archive</button>
			}
		</div>
	</div>
}

templ ChatAgentSessionLoadMore(nextCursor string, endpoints ChatAgentEndpoints, oob bool) {
	if nextCursor != "" {
		if oob {
			<div class="pt-4 text-center" id="chatagent-sessions-load-more" hx-swap-oob="true">
				<button
					class="btn btn-sm btn-ghost"
					hx-get={ templ.URL(ChatAgentSessionListURL(endpoints, nextCursor)) }
					hx-target="#chatagent-session-rows"
					hx-swap="beforeend"
					data-testid="chatagent-sessions-load-more">Load more</button>
			</div>
		} else {
			<div class="pt-4 text-center" id="chatagent-sessions-load-more">
				<button
					class="btn btn-sm btn-ghost"
					hx-get={ templ.URL(ChatAgentSessionListURL(endpoints, nextCursor)) }
					hx-target="#chatagent-session-rows"
					hx-swap="beforeend"
					data-testid="chatagent-sessions-load-more">Load more</button>
			</div>
		}
	} else if oob {
		<div id="chatagent-sessions-load-more" hx-swap-oob="delete"></div>
	}
}

templ ChatAgentSessionListAppend(items []model.AgentSession, nextCursor string, endpoints ChatAgentEndpoints) {
	for _, group := range GroupAgentSessionsForList(items, time.Now()) {
		@ChatAgentSessionDayGroup(group, endpoints)
	}
	@ChatAgentSessionLoadMore(nextCursor, endpoints, true)
}

templ ChatAgentSessionDayGroup(group model.AgentSessionDayGroup, endpoints ChatAgentEndpoints) {
	<section class="agents-session-day-group" data-testid={ "chatagent-session-day-" + group.Key }>
		<h3 class="agents-session-day-label">{ group.Label }</h3>
		for _, item := range group.Items {
			@ChatAgentSessionRow(item, endpoints)
		}
	</section>
}

templ ChatAgentSessionListFilters(endpoints ChatAgentEndpoints) {
	<div class="agents-session-filters join" data-testid="chatagent-session-filters">
		<button
			type="button"
			class={ "btn btn-xs join-item", templ.KV("btn-active", endpoints.Filter == "") }
			hx-get={ templ.URL(ChatAgentSessionListURL(ChatAgentEndpoints{ListURL: endpoints.ListURL, Filter: ""}, "")) }
			hx-target="#chatagent-session-list"
			hx-swap="outerHTML"
			data-testid="chatagent-filter-all">All</button>
		<button
			type="button"
			class={ "btn btn-xs join-item", templ.KV("btn-active", endpoints.Filter == "running") }
			hx-get={ templ.URL(ChatAgentSessionListURL(ChatAgentEndpoints{ListURL: endpoints.ListURL, Filter: "running"}, "")) }
			hx-target="#chatagent-session-list"
			hx-swap="outerHTML"
			data-testid="chatagent-filter-running">Running</button>
		<button
			type="button"
			class={ "btn btn-xs join-item", templ.KV("btn-active", endpoints.Filter == "needs_approval") }
			hx-get={ templ.URL(ChatAgentSessionListURL(ChatAgentEndpoints{ListURL: endpoints.ListURL, Filter: "needs_approval"}, "")) }
			hx-target="#chatagent-session-list"
			hx-swap="outerHTML"
			data-testid="chatagent-filter-needs-approval">
			Needs approval
			if endpoints.PendingApprovalCount > 0 {
				@ApprovalCountBadge(endpoints.PendingApprovalCount)
			}
		</button>
		<button
			type="button"
			class={ "btn btn-xs join-item", templ.KV("btn-active", endpoints.Filter == "archived") }
			hx-get={ templ.URL(ChatAgentSessionListURL(ChatAgentEndpoints{ListURL: endpoints.ListURL, Filter: "archived"}, "")) }
			hx-target="#chatagent-session-list"
			hx-swap="outerHTML"
			data-testid="chatagent-filter-archived">Archived</button>
	</div>
}

templ ChatAgentSessionList(items []model.AgentSession, nextCursor string, endpoints ChatAgentEndpoints) {
	<div class="agents-session-list" id="chatagent-session-list" data-testid="chatagent-session-list">
		<div class="agents-session-list-header">
			<span class="agents-session-list-label">Your sessions</span>
			<div class="agents-session-list-header-actions">
				@ChatAgentSessionListFilters(endpoints)
				<button
					hx-get={ templ.URL(ChatAgentSessionListURL(endpoints, "")) }
					hx-target="#chatagent-session-list"
					hx-swap="outerHTML"
					class="btn btn-ghost btn-xs text-base-content/50"
					data-testid="chatagent-sessions-refresh">
					Refresh
					@HtmxIndicator()
				</button>
			</div>
		</div>
		<div id="chatagent-session-rows" class="agents-session-rows">
			for _, group := range GroupAgentSessionsForList(items, time.Now()) {
				@ChatAgentSessionDayGroup(group, endpoints)
			}
			if len(items) == 0 {
				<div id="chatagent-sessions-empty" class="agents-session-empty">
					if endpoints.Filter == "archived" {
						No archived sessions.
					} else if endpoints.Filter == "running" {
						No running sessions.
					} else if endpoints.Filter == "needs_approval" {
						No sessions need approval.
					} else {
						No sessions yet. Start one above.
					}
				</div>
			}
		</div>
		@ChatAgentSessionLoadMore(nextCursor, endpoints, false)
	</div>
}
