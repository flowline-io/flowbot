package partials

import "github.com/flowline-io/flowbot/pkg/types/model"

templ AgentSubagentTaskTable(items []model.AgentSubagentTask) {
	<div class="card bg-base-100 shadow-sm">
		<div id="agent-subagent-tasks-table"
			data-testid="agent-subagent-tasks-table"
			class="overflow-x-auto">
			<table class="table">
				<thead>
				<tr>
					<th class="text-xs uppercase">ID</th>
					<th class="text-xs uppercase">Subagent</th>
					<th class="text-xs uppercase">Description</th>
					<th class="text-xs uppercase">Session</th>
					<th class="text-xs uppercase">Status</th>
					<th class="text-xs uppercase">Started</th>
					<th class="text-xs uppercase">Duration</th>
					<th class="text-xs uppercase">Actions</th>
				</tr>
				</thead>
				<tbody id="agent-subagent-tasks-rows">
				for _, item := range items {
					@AgentSubagentTaskRow(item)
				}
				if len(items) == 0 {
					<tr id="agent-subagent-tasks-empty">
						<td colspan="8" class="text-center text-base-content/50">No delegated tasks found.</td>
					</tr>
				}
				</tbody>
			</table>
		</div>
	</div>
}
