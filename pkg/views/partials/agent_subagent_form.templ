package partials

import "github.com/flowline-io/flowbot/pkg/types/model"

templ AgentSubagentForm(params model.AgentSubagentFormParams) {
	<tr id={ agentSubagentFormID(params.Item, params.IsNew) }>
		<td colspan="7" class="bg-base-200/50">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-4 p-4">
				<div>
					<label class="label"><span class="label-text">Flag</span></label>
					<input type="text" name="flag" value={ params.Item.Flag }
						data-testid="agent-subagent-flag"
						class={ "input input-bordered input-sm w-full font-mono " + fieldError(params.Errors, "flag") }
						placeholder="code-reviewer"
						required maxlength="128"
						if !params.IsNew {
							readonly="readonly"
						}
					/>
					<div class="text-error text-xs">{ params.Errors["flag"] }</div>
				</div>
				<div>
					<label class="label"><span class="label-text">Name</span></label>
					<input type="text" name="name" value={ params.Item.Name }
						data-testid="agent-subagent-name"
						class={ "input input-bordered input-sm w-full " + fieldError(params.Errors, "name") }
						placeholder="code-reviewer"
						required maxlength="128"
					/>
					<p class="text-xs text-base-content/50 mt-1">Referenced as subagent_type by the delegate_subagent tool and shown in the agent prompt.</p>
					<div class="text-error text-xs">{ params.Errors["name"] }</div>
				</div>
				<div class="md:col-span-2">
					<label class="label"><span class="label-text">Description</span></label>
					<input type="text" name="description" value={ params.Item.Description }
						data-testid="agent-subagent-description"
						class={ "input input-bordered input-sm w-full " + fieldError(params.Errors, "description") }
						placeholder="When the primary agent should delegate to this subagent"
					/>
					<div class="text-error text-xs">{ params.Errors["description"] }</div>
				</div>
				<div>
					<label class="label"><span class="label-text">Model</span></label>
					<input type="text" name="model" value={ params.Item.Model }
						data-testid="agent-subagent-model"
						class="input input-bordered input-sm w-full font-mono"
						placeholder="Optional model override (defaults to chat model)"
					/>
				</div>
				<div>
					<label class="label"><span class="label-text">Source</span></label>
					<input type="text" name="source" value={ params.Item.Source }
						data-testid="agent-subagent-source"
						class="input input-bordered input-sm w-full"
						placeholder="global"
					/>
				</div>
				<div class="md:col-span-2">
					<label class="label"><span class="label-text">Tools</span></label>
					<p class="text-xs text-base-content/50 mb-2">Leave all unchecked to inherit default tools for the subagent.</p>
					<div class="grid grid-cols-2 md:grid-cols-3 gap-2 rounded-lg border border-base-300 p-3 bg-base-100">
						for _, toolName := range params.AvailableTools {
							<label class="flex items-center gap-2 text-sm cursor-pointer">
								<input type="checkbox" name="tools" value={ toolName }
									data-testid={ "agent-subagent-tool-" + toolName }
									class="checkbox checkbox-xs"
									if agentSubagentOptionSelected(params.Item.Tools, toolName) {
										checked
									}
								/>
								<span class="font-mono text-xs">{ toolName }</span>
							</label>
						}
					</div>
				</div>
				<div class="md:col-span-2">
					<label class="label"><span class="label-text">Skills</span></label>
					<p class="text-xs text-base-content/50 mb-2">Selected skills are injected into the subagent prompt and enabled via read_skill.</p>
					if len(params.AvailableSkills) == 0 {
						<p class="text-xs text-base-content/50">No enabled skills. Create skills under Agent → Skills.</p>
					} else {
						<div class="grid grid-cols-1 md:grid-cols-2 gap-2 rounded-lg border border-base-300 p-3 bg-base-100 max-h-48 overflow-y-auto">
							for _, skill := range params.AvailableSkills {
								<label class="flex items-start gap-2 text-sm cursor-pointer">
									<input type="checkbox" name="skills" value={ skill.Name }
										data-testid={ "agent-subagent-skill-" + skill.Name }
										class="checkbox checkbox-xs mt-0.5"
										if agentSubagentOptionSelected(params.Item.Skills, skill.Name) {
											checked
										}
									/>
									<span>
										<span class="font-medium">{ skill.Name }</span>
										<span class="text-xs text-base-content/50 block">{ agentSubagentDescriptionPreview(skill.Description) }</span>
									</span>
								</label>
							}
						</div>
					}
				</div>
				<div class="md:col-span-2">
					<label class="label"><span class="label-text">System Prompt</span></label>
					<textarea name="system_prompt" rows="12"
						data-testid="agent-subagent-system-prompt"
						class={ "textarea textarea-bordered w-full font-mono text-sm " + fieldError(params.Errors, "system_prompt") }
						placeholder="Instructions defining the subagent persona and task focus">{ params.Item.SystemPrompt }</textarea>
					<div class="text-error text-xs">{ params.Errors["system_prompt"] }</div>
				</div>
				<div class="flex flex-col gap-2 md:col-span-2">
					<label class="label cursor-pointer justify-start gap-2">
						<input type="checkbox" name="enabled" value="true"
							data-testid="agent-subagent-enabled"
							class="checkbox checkbox-sm"
							if params.Item.Enabled || params.IsNew {
								checked
							}
						/>
						<span class="label-text">Enabled</span>
					</label>
				</div>
				<div class="flex items-end gap-2 md:col-span-2">
					<button type="button"
						if params.IsNew {
							hx-post="/service/web/agent-subagents"
						} else {
							hx-put={ agentSubagentURL(params.Item) }
						}
						hx-target="closest tr"
						hx-swap="outerHTML"
						hx-include="closest tr"
						data-testid="agent-subagent-save"
						class="btn btn-primary btn-sm">
						Save
					</button>
					<button type="button"
						hx-get={ agentSubagentCancelURL() }
						hx-target="#agent-subagents-table"
						hx-swap="outerHTML"
						data-testid="agent-subagent-cancel"
						class="btn btn-ghost btn-sm">
						Cancel
					</button>
				</div>
			</div>
		</td>
	</tr>
}
