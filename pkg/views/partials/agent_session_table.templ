package partials

import (
	"github.com/flowline-io/flowbot/pkg/types/model"
)

const agentSessionsListURL = "/service/web/agent-sessions/list"
const agentSessionsLoadMoreID = "agent-sessions-load-more"
const agentSessionsRowsTarget = "#agent-sessions-rows"

templ AgentSessionTable(items []model.AgentSession, nextCursor string) {
	<div class="flowbot-surface" id="agent-sessions-table" data-testid="agent-sessions-table">
		<div class="overflow-x-auto">
			<table class="table flowbot-table-pin">
				<thead>
				<tr>
					<th class="text-xs text-base-content/55">Title</th>
					<th class="text-xs text-base-content/55">Session ID</th>
					<th class="text-xs text-base-content/55">UID</th>
					<th class="text-xs text-base-content/55 text-center">State</th>
					<th class="text-xs text-base-content/55">Leaf ID</th>
					<th class="text-xs text-base-content/55">Updated</th>
					<th class="text-xs text-base-content/55">Created</th>
				</tr>
				</thead>
				<tbody id="agent-sessions-rows">
				for _, item := range items {
					@AgentSessionRow(item)
				}
				if len(items) == 0 {
					<tr id="agent-sessions-empty">
						<td colspan="7" class="p-0">
							@EmptyStateCTA(
								"No sessions yet",
								"Conversations appear here after you chat with an agent.",
								"/service/web/agents",
								"Open Agents",
							)
						</td>
					</tr>
				}
				</tbody>
			</table>
		</div>
		@CursorLoadMore(agentSessionsLoadMoreID, agentSessionsListURL, agentSessionsRowsTarget, nextCursor, false)
	</div>
}

// AgentSessionTableAppend renders additional session rows plus an OOB Load more control.
templ AgentSessionTableAppend(items []model.AgentSession, nextCursor string) {
	for _, item := range items {
		@AgentSessionRow(item)
	}
	@CursorLoadMore(agentSessionsLoadMoreID, agentSessionsListURL, agentSessionsRowsTarget, nextCursor, true)
}
