package partials

import (
	"github.com/flowline-io/flowbot/pkg/types/model"
)

templ AgentSubagentRow(item model.AgentSubagent) {
	<tr id={ agentSubagentRowID(item) } hx-target="this" hx-swap="outerHTML" class="hover">
		<td class="text-base-content font-mono text-sm" data-label="Flag">{ item.Flag }</td>
		<td class="text-base-content font-medium" data-label="Name">{ item.Name }</td>
		<td class="text-base-content/70 max-w-xs truncate" data-label="Description">{ agentSubagentDescriptionPreview(item.Description) }</td>
		<td class="text-base-content/70 font-mono text-sm" data-label="Model">{ agentSubagentModelLabel(item.Model) }</td>
		<td class="text-center" data-label="Enabled">
			@StatusIcon(EnabledStatusIcon(item.Enabled), "")
		</td>
		<td class="text-base-content/50" data-label="Updated">{ item.UpdatedAt.Format("2006-01-02 15:04") }</td>
		<td data-label="Actions">
			<div class="flex gap-1">
				<button hx-get={ agentSubagentEditURL(item) }
					data-testid="agent-subagent-edit"
					class="btn btn-ghost btn-xs text-primary">
					Edit
				</button>
				<button hx-delete={ agentSubagentURL(item) }
					data-confirm="Delete this subagent?"
					data-confirm-title="Delete Subagent"
					data-confirm-btn="Delete"
					data-confirm-class="btn-error"
					data-testid="agent-subagent-delete"
					class="btn btn-ghost btn-xs text-error">
					Delete
					@HtmxIndicator()
				</button>
			</div>
		</td>
	</tr>
}
