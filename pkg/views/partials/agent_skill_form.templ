package partials

import "github.com/flowline-io/flowbot/pkg/types/model"

templ AgentSkillForm(item model.AgentSkill, isNew bool, errors map[string]string) {
	<tr id={ agentSkillFormID(item, isNew) }>
		<td colspan="6" class="bg-base-200/50">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-4 p-4">
				<div>
					<label class="label"><span class="label-text">Flag</span></label>
					<input type="text" name="flag" value={ item.Flag }
						data-testid="agent-skill-flag"
						class={ "input input-bordered input-sm w-full font-mono " + fieldError(errors, "flag") }
						placeholder="karakeep"
						required maxlength="128"
						if !isNew {
							readonly="readonly"
						}
					/>
					<div class="text-error text-xs">{ errors["flag"] }</div>
				</div>
				<div>
					<label class="label"><span class="label-text">Name</span></label>
					<input type="text" name="name" value={ item.Name }
						data-testid="agent-skill-name"
						class={ "input input-bordered input-sm w-full " + fieldError(errors, "name") }
						placeholder="karakeep"
						required maxlength="128"
					/>
					<p class="text-xs text-base-content/50 mt-1">Used by read_skill and shown in the agent prompt (independent of Flag).</p>
					<div class="text-error text-xs">{ errors["name"] }</div>
				</div>
				<div class="md:col-span-2">
					<label class="label"><span class="label-text">Description</span></label>
					<input type="text" name="description" value={ item.Description }
						data-testid="agent-skill-description"
						class={ "input input-bordered input-sm w-full " + fieldError(errors, "description") }
						placeholder="Short description shown in the agent prompt"
					/>
					<div class="text-error text-xs">{ errors["description"] }</div>
				</div>
				<div>
					<label class="label"><span class="label-text">Base Directory</span></label>
					<input type="text" name="base_dir" value={ item.BaseDir }
						data-testid="agent-skill-base-dir"
						class="input input-bordered input-sm w-full font-mono"
						placeholder="Optional relative path for skill files"
					/>
				</div>
				<div>
					<label class="label"><span class="label-text">Source</span></label>
					<input type="text" name="source" value={ item.Source }
						data-testid="agent-skill-source"
						class="input input-bordered input-sm w-full"
						placeholder="global"
					/>
				</div>
				<div class="md:col-span-2">
					<label class="label"><span class="label-text">Content</span></label>
					<textarea name="content" rows="12"
						data-testid="agent-skill-content"
						class={ "textarea textarea-bordered w-full font-mono text-sm " + fieldError(errors, "content") }
						placeholder="# Skill title&#10;&#10;Markdown body loaded by read_skill">{ item.Content }</textarea>
					<div class="text-error text-xs">{ errors["content"] }</div>
				</div>
				<div class="flex flex-col gap-2">
					<label class="label cursor-pointer justify-start gap-2">
						<input type="checkbox" name="enabled" value="true"
							data-testid="agent-skill-enabled"
							class="checkbox checkbox-sm"
							if item.Enabled || isNew {
								checked
							}
						/>
						<span class="label-text">Enabled</span>
					</label>
					<label class="label cursor-pointer justify-start gap-2">
						<input type="checkbox" name="disable_model_invocation" value="true"
							data-testid="agent-skill-disable-invocation"
							class="checkbox checkbox-sm"
							if item.DisableModelInvocation {
								checked
							}
						/>
						<span class="label-text">Disable model invocation (hidden from prompt and read_skill)</span>
					</label>
				</div>
				<div class="flex items-end gap-2">
					<button type="button"
						if isNew {
							hx-post="/service/web/agent-skills"
						} else {
							hx-put={ agentSkillURL(item) }
						}
						hx-target="closest tr"
						hx-swap="outerHTML"
						hx-include="closest tr"
						data-testid="agent-skill-save"
						class="btn btn-primary btn-sm">
						Save
					</button>
					<button type="button"
						hx-get={ agentSkillCancelURL() }
						hx-target="#agent-skills-table"
						hx-swap="outerHTML"
						data-testid="agent-skill-cancel"
						class="btn btn-ghost btn-sm">
						Cancel
					</button>
				</div>
				if !isNew {
					<div id={ agentSkillFilesContainerID(item) }
						class="md:col-span-2"
						hx-get={ agentSkillFilesListURL(item) }
						hx-trigger="load"
						hx-swap="innerHTML">
						@PanelSkeleton()
					</div>
				}
			</div>
		</td>
	</tr>
}
