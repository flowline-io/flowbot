package partials

import "github.com/flowline-io/flowbot/pkg/types/model"

templ AgentMemoryTable(items []model.AgentMemoryFact, scope string) {
	<div id="agent-memory-table" class="overflow-x-auto" data-testid="agent-memory-table">
		<table class="table table-sm">
			<thead>
				<tr>
					<th>Key</th>
					<th>Value</th>
					<th>Pinned</th>
					<th>Updated</th>
					<th></th>
				</tr>
			</thead>
			<tbody>
				if len(items) == 0 {
					<tr>
						<td colspan="5" class="text-base-content/60">No facts in scope { scope }. Create facts with memory_set.</td>
					</tr>
				} else {
					for _, item := range items {
						<tr data-testid={ "agent-memory-row-" + item.Key }>
							<td class="font-mono text-sm align-top">{ item.Key }</td>
							<td colspan="3" class="p-2">
								<form class="flex flex-col gap-2 m-0"
									hx-post="/service/web/agent-memory/facts/save"
									hx-target="#agent-memory-table"
									hx-swap="outerHTML">
									<input type="hidden" name="scope" value={ scope }/>
									<input type="hidden" name="key" value={ item.Key }/>
									<textarea name="value" class="textarea textarea-bordered textarea-sm w-full font-mono text-sm" rows="2"
										data-testid={ "agent-memory-value-" + item.Key }>{ item.Value }</textarea>
									<label class="label cursor-pointer justify-start gap-2 py-0">
										<input type="checkbox" name="pinned" class="checkbox checkbox-sm"
											data-testid={ "agent-memory-pinned-" + item.Key }
											if item.Pinned {
												checked
											}
										/>
										<span class="label-text text-sm">Pinned</span>
									</label>
									<div class="flex gap-2">
										<button type="submit" class="btn btn-primary btn-xs" data-testid={ "agent-memory-save-" + item.Key }>
											Save
											@HtmxIndicator()
										</button>
									</div>
								</form>
							</td>
							<td class="align-top">
								<form class="m-0"
									hx-post="/service/web/agent-memory/facts/delete"
									hx-target="#agent-memory-table"
									hx-swap="outerHTML"
									data-confirm={ "Delete fact " + item.Key + "?" }
									data-confirm-title="Delete Fact"
									data-confirm-btn="Delete"
									data-confirm-class="btn-error">
									<input type="hidden" name="scope" value={ scope }/>
									<input type="hidden" name="key" value={ item.Key }/>
									<button type="submit" class="btn btn-ghost btn-xs text-error" data-testid={ "agent-memory-delete-" + item.Key }>
										Delete
										@HtmxIndicator()
									</button>
								</form>
								<p class="text-xs text-base-content/50 mt-2">{ item.UpdatedAt.Format("2006-01-02 15:04") }</p>
							</td>
						</tr>
					}
				}
			</tbody>
		</table>
	</div>
}
