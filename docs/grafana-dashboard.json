  "description": "Flowbot service dashboard — metrics from PushGateway + traces from OTLP/Tempo. Covers modules, features (bookmarks, torrents, RSS, kanban, gitea), infrastructure (Docker, uptime monitors), events, and request tracing.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "tags": [],
      "targetBlank": true,
      "title": "Flowbot Repo",
      "url": "https://github.com/flowline-io/flowbot"
    }
  ],
